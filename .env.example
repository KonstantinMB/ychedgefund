# Atlas Environment Variables

# API Keys (all optional for MVP, public APIs work without keys)
VITE_FINNHUB_API_KEY=
VITE_COINGECKO_API_KEY=
VITE_FRED_API_KEY=
VITE_GROQ_API_KEY=
VITE_OPENSKY_USERNAME=
VITE_OPENSKY_PASSWORD=
VITE_AISSTREAM_API_KEY=
VITE_NASA_FIRMS_API_KEY=
VITE_ACLED_API_KEY=

# Upstash Redis (for caching)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Railway WebSocket Relay
VITE_RELAY_WS_URL=ws://localhost:8080

# Development
VITE_API_BASE_URL=/api
