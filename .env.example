# Atlas Environment Variables
# Copy this file to .env and fill in your keys

# ── Upstash Redis (optional for local dev — falls back to memory-only cache) ──
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Vercel ────────────────────────────────────────────────────────────────────
VERCEL_URL=https://your-project.vercel.app

# ── Market data ───────────────────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_key
COINGECKO_API_KEY=your_coingecko_key
FRED_API_KEY=your_fred_key

# ── AI inference ──────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key

# ── OSINT data ────────────────────────────────────────────────────────────────
ACLED_API_KEY=your_acled_key
NASA_FIRMS_API_KEY=your_nasa_firms_key

# ── Railway WebSocket relay ───────────────────────────────────────────────────
# Set on Railway dashboard for the relay service
AISSTREAM_API_KEY=your_aisstream_key
OPENSKY_USERNAME=your_opensky_username
OPENSKY_PASSWORD=your_opensky_password

# ── Client-side relay URL (Vite) ──────────────────────────────────────────────
# Used by the frontend to connect to the WebSocket relay
VITE_RELAY_URL=wss://atlas-relay.up.railway.app/ws
