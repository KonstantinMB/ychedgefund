# YC Hedge Fund Environment Variables
# Copy this file to .env and fill in your keys
# Obtain free keys at the URLs listed in each section

# ── Upstash Redis ──────────────────────────────────────────────────────────────
# https://console.upstash.com — create a Redis database, copy REST credentials
# Optional for local dev (falls back to in-memory cache only)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Vercel ────────────────────────────────────────────────────────────────────
# Auto-set by Vercel on deployment; set manually for local dev if needed
VERCEL_URL=https://your-project.vercel.app

# ── Market data ───────────────────────────────────────────────────────────────
# Finnhub: https://finnhub.io — free tier, 60 req/minLive feed rate-limited — showing curated intelligence

FINNHUB_API_KEY=your_finnhub_key

# CoinGecko: https://www.coingecko.com/en/api — demo key, 30 req/min
COINGECKO_API_KEY=your_coingecko_key

# FRED (St. Louis Fed): https://fred.stlouisfed.org/docs/api/api_key.html — free
FRED_API_KEY=your_fred_key

# ── AI inference ──────────────────────────────────────────────────────────────
# Groq: https://console.groq.com — free tier, 14.4K tokens/min (Llama 3.1 8B)
GROQ_API_KEY=your_groq_key

# ── OSINT data ────────────────────────────────────────────────────────────────
# ACLED: https://acleddata.com/register — free for non-commercial research
ACLED_API_KEY=your_acled_key
ACLED_EMAIL=your_acled_email@example.com

# NASA FIRMS (fire detection): https://firms.modaps.eosdis.nasa.gov/api/
NASA_FIRMS_KEY=your_nasa_firms_key

# ── OpenSky Network (aircraft positions) ─────────────────────────────────────
# https://opensky-network.org — free account, OAuth2 client credentials
# Create an API client at: https://opensky-network.org/my-account
OPENSKY_CLIENT_ID=your_opensky_client_id
OPENSKY_CLIENT_SECRET=your_opensky_client_secret

# ── AIS vessel stream (Railway relay only) ────────────────────────────────────
# https://aisstream.io — free API key for vessel AIS WebSocket stream
AISSTREAM_API_KEY=your_aisstream_key

# ── Railway WebSocket relay ───────────────────────────────────────────────────
# Set AISSTREAM_API_KEY on Railway for vessel (AIS) tracking.
# OpenSky (aircraft) is often blocked from Railway IPs — see docs/RAILWAY-RELAY.md

# ── Client-side env vars (prefixed VITE_) ─────────────────────────────────────
# URL of the Railway WebSocket relay for real-time AIS + aircraft streams
VITE_RELAY_URL=wss://your-relay.up.railway.app/ws
